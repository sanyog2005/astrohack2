---
// src/components/SpaceButtons.astro
---

<div class="flex items-center justify-center gap-6 mt-20">
  
  <button class="relative group px-8 py-3.5 rounded-full overflow-hidden transition-all duration-300 hover:scale-[1.02] active:scale-95 shadow-[0_0_40px_-15px_rgba(168,85,247,0.4)] hover:shadow-[0_0_60px_-15px_rgba(168,85,247,0.6)] cursor-pointer">
    
    <div class="absolute inset-[-100%] animate-[spin_4s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#000000_0%,#000000_50%,#d8b4fe_100%)] group-hover:bg-[conic-gradient(from_90deg_at_50%_50%,#000000_0%,#000000_50%,#c084fc_100%)] opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>

    <div class="absolute inset-[1px] rounded-full bg-[#07050f] transition-colors duration-500 group-hover:bg-[#07050f]/80 backdrop-blur-xl z-10"></div>

    <div class="absolute top-0 -inset-full h-full w-1/2 z-20 block transform -skew-x-12 bg-gradient-to-r from-transparent via-white/15 to-transparent opacity-0 group-hover:animate-[sweep_1.5s_ease-in-out_infinite]"></div>

    <span class="relative z-30 font-semibold tracking-widest text-[13px] uppercase text-white/90 group-hover:text-white transition-colors duration-300 drop-shadow-[0_0_10px_rgba(255,255,255,0.3)] group-hover:drop-shadow-[0_0_12px_rgba(216,180,254,0.8)]">
      Get Started
    </span>
  </button>

  <button class="relative group px-8 py-3.5 rounded-full bg-white/5 border border-white/10 overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:bg-white/10 hover:border-white/20 hover:shadow-[0_0_30px_-5px_rgba(255,255,255,0.1)] active:scale-95 cursor-pointer backdrop-blur-xl">
    <span class="relative z-10 font-medium tracking-widest text-[13px] uppercase text-white/60 group-hover:text-white transition-colors duration-300">
      View Docs
    </span>
  </button>

</div>

<style>
  /* Light-speed shimmer sweep on hover */
  @keyframes sweep {
    0% { left: -100%; opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { left: 200%; opacity: 0; }
  }
</style>