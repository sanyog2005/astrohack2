---
// src/components/StackScrollSection.astro
---

<section class="bg-black text-gray-300 font-sans relative selection:bg-white selection:text-black">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col lg:flex-row relative">

    <div class="lg:w-[45%] relative pb-[2vh] pt-[15vh]">
      
      <div class="scroll-step h-[80vh] flex flex-col justify-center transition-all duration-500 ease-out" data-step="1">
         <div class="step-content relative p-8 md:p-12 w-full max-w-lg transition-all duration-500 text-gray-600">
            <div class="corner-marker absolute top-0 left-0 w-2 h-2 border-t border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute top-0 right-0 w-2 h-2 border-t border-r border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 left-0 w-2 h-2 border-b border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 right-0 w-2 h-2 border-b border-r border-transparent transition-colors duration-500"></div>
            
            <p class="text-[10px] tracking-[0.2em] uppercase mb-6 font-semibold opacity-80">The Challenge</p>
            <h2 class="text-4xl md:text-5xl font-mono tracking-tight mb-6 leading-tight text-current transition-colors duration-500">Space runs on code.</h2>
            <p class="text-sm leading-relaxed opacity-80">From low-earth orbit to deep space probes, software is the critical infrastructure of the cosmos. We need engineers to build the next generation of reliable, autonomous systems.</p>
         </div>
      </div>

      <div class="scroll-step h-[80vh] flex flex-col justify-center transition-all duration-500 ease-out" data-step="2">
         <div class="step-content relative p-8 md:p-12 w-full max-w-lg transition-all duration-500 text-gray-600">
            <div class="corner-marker absolute top-0 left-0 w-2 h-2 border-t border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute top-0 right-0 w-2 h-2 border-t border-r border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 left-0 w-2 h-2 border-b border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 right-0 w-2 h-2 border-b border-r border-transparent transition-colors duration-500"></div>

            <p class="text-[10px] tracking-[0.2em] uppercase mb-6 font-semibold opacity-80">The Environment</p>
            <h2 class="text-4xl md:text-5xl font-mono tracking-tight mb-6 leading-tight text-current transition-colors duration-500">Extreme solutions.</h2>
            <p class="text-sm leading-relaxed opacity-80">High latency, limited bandwidth, and radiation interference. You must design architectures that can survive and thrive when help is millions of miles away.</p>
         </div>
      </div>

      <div class="scroll-step h-[80vh] flex flex-col justify-center transition-all duration-500 ease-out" data-step="3">
         <div class="step-content relative p-8 md:p-12 w-full max-w-lg transition-all duration-500 text-gray-600">
            <div class="corner-marker absolute top-0 left-0 w-2 h-2 border-t border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute top-0 right-0 w-2 h-2 border-t border-r border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 left-0 w-2 h-2 border-b border-l border-transparent transition-colors duration-500"></div>
            <div class="corner-marker absolute bottom-0 right-0 w-2 h-2 border-b border-r border-transparent transition-colors duration-500"></div>

            <p class="text-[10px] tracking-[0.2em] uppercase mb-6 font-semibold opacity-80">The Opportunity</p>
            <h2 class="text-4xl md:text-[44px] font-mono tracking-tight mb-6 leading-tight text-current transition-colors duration-500">Leave your mark on the stars.</h2>
            <p class="text-sm leading-relaxed opacity-80">This isn't just another weekend project. You will build tools that solve real problems faced by modern space agencies and commercial launch providers.</p>
         </div>
      </div>

    </div>

    <div class="lg:w-[55%] sticky top-0 h-screen flex flex-col justify-center pl-8 lg:pl-20">
       <div class="relative w-full max-w-xl">

          <div class="absolute left-6 top-10 bottom-10 w-[1px] border-l border-dashed border-gray-100 -z-10"></div>

          <div class="flex flex-col w-full" id="stack-animation-container">

            <div class="relative bg-black border border-dashed border-gray-100 p-8 z-10 w-full">
              <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-gray-100"></div>
              <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-gray-100"></div>
              <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-gray-100"></div>
              <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-gray-100"></div>
              
              <h3 class="text-xl font-mono text-gray-300">Your Crew</h3>
              <p class="text-xs text-gray-500 mt-2">Form a team of up to 4 students.</p>
            </div>

            <div id="stack-step-2" class="grid transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]" style="grid-template-rows: 0fr; opacity: 0; margin-top: 0;">
              <div class="overflow-hidden">
                <div class="relative bg-black border border-dashed border-gray-100 p-8 z-10 w-full">
                  <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-gray-100"></div>
                  <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-gray-100"></div>
                  
                  <div class="flex justify-between items-center">
                    <div>
                      <h3 class="text-xl font-mono text-gray-300">Hackathon Mentors</h3>
                      <p class="text-xs text-gray-500 mt-2">Industry experts to guide your trajectory.</p>
                    </div>
                    <div class="flex flex-col items-center gap-[4px] shrink-0 mr-4">
                      <div class="flex gap-[4px]"><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div></div>
                      <div class="flex gap-[4px]"><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div></div>
                      <div class="flex gap-[4px]"><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div></div>
                      <div class="flex gap-[4px]"><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div><div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div id="stack-step-3" class="grid transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]" style="grid-template-rows: 0fr; opacity: 0; margin-top: 0;">
              <div class="overflow-hidden">
                <div class="relative bg-black border border-dashed border-gray-100 p-8 z-10 w-full">
                  <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-gray-100"></div>
                  <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-gray-100"></div>
                  
                  <h3 class="text-xl font-mono text-gray-300">Space APIS & Data</h3>
                  <p class="text-xs text-gray-500 mt-2 mb-6">Access raw telemetry and orbital datasets.</p>
                  
                  <div class="flex items-center gap-6 text-gray-500">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
                    <span class="text-[10px] font-semibold border border-dashed border-gray-100 rounded px-2 py-1 ml-auto">+ 92 more</span>
                  </div>
                </div>
              </div>
            </div>

            <div id="stack-step-4" class="grid transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]" style="grid-template-rows: 1fr; margin-top: 1.5rem;">
              <div class="overflow-hidden">
                <div class="relative bg-black border border-dashed border-gray-100 p-8 z-10 w-full">
                  <div class="absolute -top-[1px] -left-[1px] w-2 h-2 border-t border-l border-gray-100"></div>
                  <div class="absolute -top-[1px] -right-[1px] w-2 h-2 border-t border-r border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -left-[1px] w-2 h-2 border-b border-l border-gray-100"></div>
                  <div class="absolute -bottom-[1px] -right-[1px] w-2 h-2 border-b border-r border-gray-100"></div>
                  
                  <h3 class="text-xl font-mono text-gray-300">Launch Day</h3>
                  <p class="text-xs text-gray-500 mt-2">Deploy your projects and pitch to our panel of judges.</p>
                </div>
              </div>
            </div>

          </div>
       </div>
    </div>

  </div>
</section>

<style>
  /* Active state classes applied by JavaScript */
  .is-active .step-content {
    background-color: #111111;
    color: #d1d5db; /* gray-300 */
  }
  
  .is-active .corner-marker {
    border-color: #4b5563; /* gray-600 */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const steps = document.querySelectorAll('.scroll-step');
    const step2Box = document.getElementById('stack-step-2');
    const step3Box = document.getElementById('stack-step-3');

    // Intersection Observer to track which text block is active
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          
          // 1. Reset all text blocks to inactive (dimmed text, transparent bg)
          steps.forEach(s => {
            s.classList.remove('is-active');
            const content = s.querySelector('.step-content');
            if(content) content.classList.add('text-gray-600');
          });

          // 2. Set current block to active (highlighted bg, bright text)
          entry.target.classList.add('is-active');
          const activeContent = entry.target.querySelector('.step-content');
          if(activeContent) activeContent.classList.remove('text-gray-600');

          // 3. Trigger Right Side Animations based on the step number
          const stepNum = entry.target.getAttribute('data-step');
          
          if (step2Box && step3Box) {
            if (stepNum === '1') {
              // Hide Middle Boxes
              step2Box.style.gridTemplateRows = '0fr';
              step2Box.style.opacity = '0';
              step2Box.style.marginTop = '0';
              
              step3Box.style.gridTemplateRows = '0fr';
              step3Box.style.opacity = '0';
              step3Box.style.marginTop = '0';
            } 
            else if (stepNum === '2') {
              // Show Agents, Hide World Model
              step2Box.style.gridTemplateRows = '1fr';
              step2Box.style.opacity = '1';
              step2Box.style.marginTop = '1.5rem'; // 24px gap
              
              step3Box.style.gridTemplateRows = '0fr';
              step3Box.style.opacity = '0';
              step3Box.style.marginTop = '0';
            } 
            else if (stepNum === '3') {
              // Show Both Middle Boxes
              step2Box.style.gridTemplateRows = '1fr';
              step2Box.style.opacity = '1';
              step2Box.style.marginTop = '1.5rem';
              
              step3Box.style.gridTemplateRows = '1fr';
              step3Box.style.opacity = '1';
              step3Box.style.marginTop = '1.5rem';
            }
          }
        }
      });
    }, {
      // Trigger when the element enters the middle 40% of the viewport height
      rootMargin: '-30% 0px -30% 0px',
      threshold: 0
    });

    steps.forEach(step => observer.observe(step));
  });
</script>