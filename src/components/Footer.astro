---
// src/components/Footer.astro
---

<section class="bg-[#0a0a0a] border-y border-dashed border-white/10 font-serif text-gray-200 selection:bg-white/20 ">
  
  <div class="grid grid-cols-2 lg:grid-cols-6 lg:divide-x divide-dashed divide-white/10">

    <div class="relative p-6 md:p-8 lg:p-10 flex flex-col h-full min-h-[220px] lg:min-h-[340px] group col-span-1 border-b border-r lg:border-b-0 lg:border-r-0 border-dashed border-white/10">
      <div class="absolute top-3 left-3 w-2 h-2 border-t border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute top-3 right-3 w-2 h-2 border-t border-r border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 left-3 w-2 h-2 border-b border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 right-3 w-2 h-2 border-b border-r border-white/10 transition-colors group-hover:border-white/30"></div>

      <div class="text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase mb-6 lg:mb-10">Tracks</div>
      <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">
        Orbital Software<br>Engineering
      </a>
    </div>

    <div class="relative p-6 md:p-8 lg:p-10 flex flex-col h-full min-h-[220px] lg:min-h-[340px] group col-span-1 border-b lg:border-b-0 border-dashed border-white/10">
      <div class="absolute top-3 left-3 w-2 h-2 border-t border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute top-3 right-3 w-2 h-2 border-t border-r border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 left-3 w-2 h-2 border-b border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 right-3 w-2 h-2 border-b border-r border-white/10 transition-colors group-hover:border-white/30"></div>

      <div class="text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase mb-6 lg:mb-10">Event</div>
      <div class="flex flex-col gap-2">
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">About Us</a>
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">Schedule</a>
      </div>
    </div>

    <div class="relative p-6 md:p-8 lg:p-10 flex flex-col h-full min-h-[220px] lg:min-h-[340px] group col-span-1 border-b border-r lg:border-b-0 lg:border-r-0 border-dashed border-white/10">
      <div class="absolute top-3 left-3 w-2 h-2 border-t border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute top-3 right-3 w-2 h-2 border-t border-r border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 left-3 w-2 h-2 border-b border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 right-3 w-2 h-2 border-b border-r border-white/10 transition-colors group-hover:border-white/30"></div>

      <div class="text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase mb-6 lg:mb-10">Resources</div>
      <div class="flex flex-col gap-2">
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">Space APIs</a>
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">Mentors</a>
      </div>
    </div>

    <div class="relative p-6 md:p-8 lg:p-10 flex flex-col h-full min-h-[220px] lg:min-h-[340px] group col-span-1 border-b lg:border-b-0 border-dashed border-white/10">
      <div class="absolute top-3 left-3 w-2 h-2 border-t border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute top-3 right-3 w-2 h-2 border-t border-r border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 left-3 w-2 h-2 border-b border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 right-3 w-2 h-2 border-b border-r border-white/10 transition-colors group-hover:border-white/30"></div>

      <div class="text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase mb-6 lg:mb-10">Information</div>
      <div class="flex flex-col gap-2">
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">Rules</a>
        <a href="#" class="font-serif text-[22px] lg:text-[26px] leading-[1.2] text-white/90 hover:text-white hover:underline decoration-1 underline-offset-4 transition-all">FAQ</a>
      </div>
    </div>

    <div class="relative p-6 md:p-8 lg:p-10 flex flex-col h-full min-h-[260px] lg:min-h-[340px] group col-span-2 lg:col-span-2">
      <div class="absolute top-3 left-3 w-2 h-2 border-t border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute top-3 right-3 w-2 h-2 border-t border-r border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 left-3 w-2 h-2 border-b border-l border-white/10 transition-colors group-hover:border-white/30"></div>
      <div class="absolute bottom-3 right-3 w-2 h-2 border-b border-r border-white/10 transition-colors group-hover:border-white/30"></div>

      <div class="flex flex-wrap items-center gap-3">
        <div class="px-3 py-1.5 bg-[#121212] border border-white/5 text-white/90 rounded-[4px] text-[9px] font-mono tracking-[0.15em] uppercase font-semibold flex items-center gap-2.5 shadow-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a3e635] shadow-[0_0_8px_rgba(163,230,53,0.4)] animate-pulse"></span>
          All Systems Nominal
        </div>
        <div class="px-3 py-1.5 bg-transparent border border-white/10 text-white/50 rounded-[4px] text-[9px] font-mono tracking-[0.15em] uppercase font-semibold">
          Built for the Cosmos
        </div>
      </div>

      <div class="mt-auto flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 lg:gap-8 pt-8 lg:pt-12">
        
        <p class="text-[10px] font-mono tracking-[0.15em] text-white/40 uppercase leading-relaxed max-w-[280px]">
          The ultimate student space hackathon.<br>
          Launch your career into orbit.
        </p>

        <div class="flex flex-col items-end gap-6 shrink-0">
          
          <svg width="44" height="40" viewBox="0 0 44 40" fill="currentColor" class="text-white/20 transition-colors group-hover:text-white/40">
            <circle cx="22" cy="6" r="3.5" />
            <circle cx="12" cy="16" r="3.5" />
            <circle cx="22" cy="16" r="3.5" />
            <circle cx="32" cy="16" r="3.5" />
            <circle cx="6" cy="26" r="3.5" />
            <circle cx="38" cy="26" r="3.5" />
            <circle cx="6" cy="36" r="3.5" />
            <circle cx="38" cy="36" r="3.5" />
          </svg>

         

        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Ensure Playfair Display is available */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap');

  .font-serif {
      font-family: 'Playfair Display', serif;
  }
</style>