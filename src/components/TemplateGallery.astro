<style>
    /* Import Playfair Display for the italic 'stunning' text */
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital@1&display=swap');

    .font-serif {
        font-family: 'Playfair Display', serif;
    }

    /* --- Marquee Animation Logic --- */
    .marquee-track-left {
        display: flex;
        width: max-content;
        animation: scroll-left 45s linear infinite;
        will-change: transform;
    }

    .marquee-track-right {
        display: flex;
        width: max-content;
        animation: scroll-right 45s linear infinite;
        will-change: transform;
    }

    /* Pause animation smoothly when the user hovers over the container */
    .marquee-container:hover .marquee-track-left,
    .marquee-container:hover .marquee-track-right {
        animation-play-state: paused;
    }

    @keyframes scroll-left {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    @keyframes scroll-right {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
    }

    /* Image Card Styling */
    .card {
        height: 240px;
        border-radius: 16px;
        overflow: hidden;
        flex-shrink: 0;
        /* Dark theme border and shadow adjustments */
        border: 1px solid #1f2937; 
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }
    
    .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
    }
</style>