<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('features-section');
    const letters = document.querySelectorAll('.animate-letter');
    
    // NEW: Selectors for the auto-scroll logic
    const exploreBtn = section?.querySelector('button');
    const cards = section?.querySelectorAll('.bg-white.border.border-gray-300');
    const lastCard = cards && cards.length > 0 ? cards[cards.length - 1] : null;
    let hasAutoScrolled = false;
    
    // State for lerping
    let scrollProgress = 0;
    let targetProgress = 0;

    const updatePeelingText = () => {
      if (!section) return;

      const rect = section.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      
      // Calculate target progress (0 to 1)
      let rawProgress = (windowHeight - rect.top) / (rect.height);
      targetProgress = Math.max(0, Math.min(1.2, rawProgress));
      
      // LERP: Smoothly approach the target progress (0.15 = 15% closer every frame)
      scrollProgress += (targetProgress - scrollProgress) * 0.15;

      letters.forEach((letter) => {
        const el = letter as HTMLElement;
        const delay = parseFloat(el.getAttribute('data-delay') || '0');
        
        // Use the smoothed scrollProgress
        let letterT = Math.max(0, (scrollProgress * 4.0) - delay);
        
        // 1. Position: Faster movement (100px drop instead of 150)
        let y = Math.max(0, 100 * (1 - Math.min(1, letterT * 2)));
        
        // 2. Opacity: Smoother, punchier fade
        let opacity = Math.min(1, letterT * 5);
        
        // 3. Rotation
        let rot = (parseFloat(el.getAttribute('data-rotation') || '0')) * (1 - Math.min(1, letterT * 2));

        // Use translate3d to force hardware acceleration
        el.style.transform = `translate3d(0, ${y}px, 0) rotate(${rot}deg)`;
        el.style.opacity = opacity.toString();
      });

      // NEW: Auto-scroll logic added here
      if (exploreBtn && lastCard) {
        const btnRect = exploreBtn.getBoundingClientRect();
        const cardRect = lastCard.getBoundingClientRect();
        
        // Trigger when the top of the last card aligns with or passes the top of the button
        if (cardRect.top <= btnRect.top && cardRect.bottom > 0) {
          if (!hasAutoScrolled) {
            hasAutoScrolled = true;
            
            // Look for the next section on the page to scroll to
            const nextSection = section.nextElementSibling;
            if (nextSection) {
              nextSection.scrollIntoView({ behavior: 'smooth' });
            } else {
              // Fallback if no next section exists: scroll to the absolute bottom of this section
              window.scrollTo({
                top: window.scrollY + cardRect.bottom,
                behavior: 'smooth'
              });
            }
          }
        } else if (cardRect.top > btnRect.bottom + 50) {
          // Reset the trigger so it works again if the user scrolls back up
          hasAutoScrolled = false;
        }
      }

      requestAnimationFrame(updatePeelingText);
    };

    // Kick off the loop
    if (section) {
      requestAnimationFrame(updatePeelingText);
    }
  });
</script>