---
const textToAnimate = "snoitatneserp tnegilletni"
const animatedWord = textToAnimate.split('');

const letterPhysics = animatedWord.map((char, index) => {
  // To make the RIGHT side ('s') animate first:
  // We want index 24 ('s') to have delay 0
  // We want index 0 ('i') to have the largest delay
  return {
    delay: (animatedWord.length - 1 - index) * 0.04,
    rotation: (Math.random() - 0.5) * 60
  };
});
