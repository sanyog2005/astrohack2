---
// src/components/ReflectHero.astro
import Globe from "../components/Globe.astro";
import SpaceButtons from "../components/SpaceButtons.astro";
---

<section
  class="relative min-h-screen bg-[#07050f] overflow-hidden flex flex-col pt-16 pb-10 lg:pt-22 lg:pb-2 font-sans selection:bg-purple-500/30"
>
  
  <div class="relative z-30 flex flex-col lg:flex-row items-center justify-between w-full max-w-7xl mx-auto px-4 md:px-6 gap-12 lg:gap-10 mb-8 lg:mb-2">
    
    <div class="flex flex-col items-center lg:items-start w-full lg:w-1/2">
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-purple-400/20 bg-purple-900/10 text-[11px] md:text-[12px] lg:text-[13px] text-purple-200 mb-6 lg:mb-8 backdrop-blur-md"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
          <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path>
        </svg>
        <span class="tracking-wide">New: Mission control is now online</span>
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-[72px] leading-[1.1] font-bold tracking-tight text-white mb-4 lg:mb-6 text-center lg:text-left drop-shadow-lg">
        Code for the Cosmos
      </h1>

      <p class="text-base md:text-lg lg:text-[21px] text-[#a19fad] text-center lg:text-left max-w-lg font-normal drop-shadow-md">
        Join the ultimate student hackathon for space-based software.
      </p>
    </div>

    <div class="w-full lg:w-1/2 flex justify-center lg:justify-end relative z-20 group">
     <div
  class="relative rounded-[20px] w-full max-w-[300px] md:max-w-[400px] lg:max-w-[470px] aspect-square lg:aspect-[3/3] flex items-center justify-center z-10"
>
  <Globe />
</div>
    </div>
    
  </div>

  <div class="relative w-full max-w-7xl mx-auto px-4 md:px-6 z-2 mt-8 lg:mt-1 flex justify-center">
    <div class="relative w-full rounded-3xl overflow-hidden bg-black shadow-2xl mix-blend-screen">
      <video
        src="/assets/q-c3d7becf.webm"
        autoplay
        loop
        muted
        playsinline
        class="w-full h-auto max-h-[250px] md:max-h-[350px] lg:max-h-[500px] object-cover opacity-90"
      ></video>

      <canvas
        id="starfield"
        class="absolute inset-0 w-full h-full z-10 opacity-70"
      ></canvas>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const canvas = document.getElementById("starfield") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    let stars = [];
    const numStars = 100;

    // Define boundary variables for both X and Y
    let minX = 0,
      maxX = 0;
    let minY = 0,
      maxY = 0;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;

      // Calculate sizes for a 3x2 grid
      const colWidth = canvas.width / 3;
      const rowHeight = canvas.height / 2;

      // Target: 2nd Column
      minX = colWidth * 1;
      maxX = colWidth * 2;

      // Target: 1st Row
      minY = 0;
      maxY = rowHeight * 1;
    }

    function initStars() {
      stars = [];
      for (let i = 0; i < numStars; i++) {
        stars.push({
          // Spawn strictly within our target grid cell
          x: minX + Math.random() * (maxX - minX),
          y: minY + Math.random() * (maxY - minY),
          vx: (Math.random() - 0.5) * 0.6,
          vy: (Math.random() - 0.5) * 0.6,
          radius: Math.random() * 1.2,
          alpha: Math.random(),
        });
      }
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      stars.forEach((star) => {
        star.x += star.vx;
        star.y += star.vy;

        // Wrap X strictly within the 2nd column bounds
        if (star.x < minX) star.x = maxX;
        if (star.x > maxX) star.x = minX;

        // Wrap Y strictly within the 1st row bounds
        if (star.y < minY) star.y = maxY;
        if (star.y > maxY) star.y = minY;

        ctx.beginPath();
        ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${star.alpha})`;
        ctx.fill();
      });

      requestAnimationFrame(animate);
    }

    window.addEventListener("resize", () => {
      resizeCanvas();
      initStars();
    });

    resizeCanvas();
    initStars();
    animate();
  });
</script>