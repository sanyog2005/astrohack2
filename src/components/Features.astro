---
// src/components/ReflectHero.astro
import Globe from "../components/Globe.astro";
import SpaceButtons from "../components/SpaceButtons.astro";
---

<section
  class="relative min-h-screen bg-[#07050f] overflow-hidden flex flex-col items-center pt-32 pb-20 font-sans selection:bg-purple-500/30"
>
  <div
    class="absolute inset-0 pointer-events-none flex items-center justify-center z-0"
  >
    <div
      class="absolute w-[600px] h-[600px] border border-white/[0.02] rounded-full"
    >
    </div>
    <div
      class="absolute w-[900px] h-[900px] border border-white/[0.02] rounded-full"
    >
    </div>
    <div
      class="absolute w-[1200px] h-[1200px] border border-white/[0.015] rounded-full"
    >
    </div>
    <div
      class="absolute top-[20%] left-[30%] w-0.5 h-0.5 bg-white/40 rounded-full blur-[0.5px]"
    >
    </div>
    <div
      class="absolute top-[25%] right-[28%] w-[3px] h-[3px] bg-purple-300/40 rounded-full blur-[1px]"
    >
    </div>
    <div
      class="absolute top-[40%] right-[35%] w-0.5 h-0.5 bg-white/30 rounded-full blur-[0.5px]"
    >
    </div>
    <div
      class="absolute top-[35%] left-[40%] w-[2px] h-[2px] bg-white/20 rounded-full blur-[0.5px]"
    >
    </div>
  </div>

  <div class="relative z-30 flex flex-col items-center w-full mb-20">
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-purple-400/20 bg-purple-900/10 text-[13px] text-purple-200 mb-8 backdrop-blur-md"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-white"
      >
        <path
          d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
        ></path>
      </svg>
      <span class="tracking-wide">New: Mission control is now online</span>
    </div>

    <h1
      class="text-5xl md:text-[72px] leading-tight font-bold tracking-tight text-white mb-5 text-center drop-shadow-lg"
    >
      Code for the Cosmos
    </h1>

    <p
      class="text-lg md:text-[21px] text-[#a19fad] text-center mb-20 max-w-2xl font-normal drop-shadow-md"
    >
      Join the ultimate student hackathon for space-based software.
    </p>
  </div>

  <div class="relative w-full flex justify-center mt-12">
    <div class="relative w-full max-w-[1100px] mx-auto z-20 group">
      <div
        class="absolute left-1/2 -translate-x-1/2 top-0 -translate-y-[50%] w-[1400px] pointer-events-none z-0 mix-blend-screen opacity-90 flex justify-center"
      >
        <video
          src="/assets/q-c3d7becf.webm"
          autoplay
          loop
          muted
          playsinline
          class="w-full h-auto max-w-none"></video>

        <canvas
          id="starfield"
          class="absolute inset-0 w-full h-full z-10 opacity-70"></canvas>
      </div>
      <div
        class="absolute -inset-[2px] bg-gradient-to-b from-black via-purple-900/5 to-transparent rounded-[22px] blur-xl opacity-90 z-0 pointer-events-none"
      >
      </div>

      <div
        class="relative rounded-[20px] max-w-[1050px] mx-auto backdrop-blur-[400px] overflow-hidden aspect-[20/10] shadow-[0_40px_100px_-10px_rgba(0,0,0,0.8),inset_0_1px_2px_rgba(255,255,255,0.1)] flex z-10 ring-1 ring-white/10"
      >
        <Globe />
        
        
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const canvas = document.getElementById("starfield") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    let stars = [];
    const numStars = 100;

    // Define boundary variables for both X and Y
    let minX = 0,
      maxX = 0;
    let minY = 0,
      maxY = 0;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;

      // Calculate sizes for a 3x2 grid
      const colWidth = canvas.width / 3;
      const rowHeight = canvas.height / 2;

      // Target: 2nd Column
      minX = colWidth * 1;
      maxX = colWidth * 2;

      // Target: 1st Row
      minY = 0;
      maxY = rowHeight * 1;
    }

    function initStars() {
      stars = [];
      for (let i = 0; i < numStars; i++) {
        stars.push({
          // Spawn strictly within our target grid cell
          x: minX + Math.random() * (maxX - minX),
          y: minY + Math.random() * (maxY - minY),
          vx: (Math.random() - 0.5) * 0.6,
          vy: (Math.random() - 0.5) * 0.6,
          radius: Math.random() * 1.2,
          alpha: Math.random(),
        });
      }
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      stars.forEach((star) => {
        star.x += star.vx;
        star.y += star.vy;

        // Wrap X strictly within the 2nd column bounds
        if (star.x < minX) star.x = maxX;
        if (star.x > maxX) star.x = minX;

        // Wrap Y strictly within the 1st row bounds
        if (star.y < minY) star.y = maxY;
        if (star.y > maxY) star.y = minY;

        ctx.beginPath();
        ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${star.alpha})`;
        ctx.fill();
      });

      requestAnimationFrame(animate);
    }

    window.addEventListener("resize", () => {
      resizeCanvas();
      initStars();
    });

    resizeCanvas();
    initStars();
    animate();
  });
</script>