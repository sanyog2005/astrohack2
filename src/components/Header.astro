---
// Just drop this in your Astro layout or component
---

<header class="fixed top-0 w-full px-4 md:px-6 py-4 flex justify-between items-center z-50 text-white animate-[slideDown_0.8s_ease-out_forwards] opacity-0 border-b border-gray-900 bg-black/30 backdrop-blur-md">
  
  <nav class="hidden md:flex items-center gap-1 px-2 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_4px_24px_-8px_rgba(0,0,0,0.5)]">
    <a href="#" class="relative px-4 py-1.5 text-sm font-medium text-gray-400 hover:text-white transition-colors duration-300 group">
      Challenges
      <span class="absolute inset-x-4 -bottom-px h-px bg-gradient-to-r from-transparent via-purple-400/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
    </a>
    <a href="#" class="relative px-4 py-1.5 text-sm font-medium text-gray-400 hover:text-white transition-colors duration-300 group">
      Schedule
      <span class="absolute inset-x-4 -bottom-px h-px bg-gradient-to-r from-transparent via-purple-400/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
    </a>
    <a href="#" class="relative px-4 py-1.5 text-sm font-medium text-gray-400 hover:text-white transition-colors duration-300 group">
      Resources
      <span class="absolute inset-x-4 -bottom-px h-px bg-gradient-to-r from-transparent via-purple-400/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
    </a>
  </nav>

  <div class="absolute left-4 md:left-1/2 md:-translate-x-1/2 flex items-center gap-2.5 px-6 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-xl hover:bg-white/10 hover:border-white/20 hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(216,180,254,0.15)] transition-all duration-300 cursor-pointer z-50">
    <div class="w-3.5 h-3.5 grid grid-cols-2 gap-[2px]">
      <div class="bg-gray-300 rounded-[1px]"></div>
      <div class="bg-gray-300 rounded-[1px]"></div>
      <div class="bg-gray-300 rounded-[1px]"></div>
      <div class="bg-gray-300 rounded-[1px]"></div>
    </div>
    <span class="font-medium tracking-wide text-sm">AstroHack</span>
  </div>

  <div class="ml-auto flex items-center gap-3 z-50">
    <div class="hidden md:flex items-center gap-2 px-2 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_4px_24px_-8px_rgba(0,0,0,0.5)]">
      <a href="#" class="px-4 text-sm font-medium text-gray-400 hover:text-white transition-colors duration-300">Hacker Portal</a>
      <button class="bg-white text-black px-5 py-1.5 rounded-full text-sm font-semibold hover:bg-gray-200 hover:scale-105 active:scale-95 transition-all duration-300 shadow-[0_0_15px_rgba(255,255,255,0.3)]">
        Register Now
      </button>
    </div>

    <button id="mobile-toggle" class="md:hidden relative flex flex-col justify-center items-center w-10 h-10 gap-1 rounded-full border border-white/10 bg-white/5 backdrop-blur-xl hover:bg-white/10 transition-colors z-50">
      <span class="w-4 h-[1.5px] bg-white rounded-full transition-transform duration-300 origin-center"></span>
      <span class="w-4 h-[1.5px] bg-white rounded-full transition-opacity duration-300"></span>
      <span class="w-4 h-[1.5px] bg-white rounded-full transition-transform duration-300 origin-center"></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="fixed inset-0 top-0 bg-[#07050f]/98 backdrop-blur-3xl pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] flex flex-col justify-center items-center z-40 opacity-0 -translate-y-full">
  <div class="flex flex-col items-center gap-6 w-full max-w-sm px-6 mt-12">
    <a href="#" class="mobile-item text-3xl font-medium text-gray-300 hover:text-white hover:scale-105 transition-all opacity-0 translate-y-8">Challenges</a>
    <a href="#" class="mobile-item text-3xl font-medium text-gray-300 hover:text-white hover:scale-105 transition-all opacity-0 translate-y-8">Schedule</a>
    <a href="#" class="mobile-item text-3xl font-medium text-gray-300 hover:text-white hover:scale-105 transition-all opacity-0 translate-y-8">Resources</a>
    
    <div class="mobile-item w-16 h-px bg-white/10 my-4 opacity-0 translate-y-8 transition-all"></div>
    
    <a href="#" class="mobile-item text-xl font-medium text-gray-400 hover:text-white transition-colors opacity-0 translate-y-8">Hacker Portal</a>
    
    <button class="mobile-item mt-4 bg-white text-black w-full py-4 rounded-full text-lg font-bold active:scale-95 transition-all opacity-0 translate-y-8 shadow-[0_0_30px_rgba(255,255,255,0.15)]">
      Register Now
    </button>
  </div>
</div>

<style>
  /* Premium load-in animation */
  @keyframes slideDown {
    0% { transform: translateY(-100%); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }
</style>

<script>
  // Mobile Menu Logic
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const items = document.querySelectorAll('.mobile-item');
  const spans = toggle?.querySelectorAll('span');
  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    
    if (isOpen) {
      // 1. Lock Body Scroll
      document.body.style.overflow = 'hidden';

      // 2. Drop the menu background
      menu?.classList.remove('opacity-0', '-translate-y-full', 'pointer-events-none');
      menu?.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      
      // 3. Animate hamburger to 'X'
      if (spans) {
        spans[0].style.transform = 'translateY(5.5px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-5.5px) rotate(-45deg)';
      }

      // 4. Staggered fade in/slide up for menu links
      items.forEach((item, index) => {
        setTimeout(() => {
          item.classList.remove('opacity-0', 'translate-y-8');
          item.classList.add('opacity-100', 'translate-y-0');
          (item as HTMLElement).style.transitionTimingFunction = 'cubic-bezier(0.22, 1, 0.36, 1)';
          (item as HTMLElement).style.transitionDuration = '700ms';
        }, 150 + (index * 75)); 
      });

    } else {
      // 1. Unlock Body Scroll
      document.body.style.overflow = '';

      // 2. Pull the menu background up
      menu?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      menu?.classList.add('opacity-0', '-translate-y-full', 'pointer-events-none');
      
      // 3. Reset hamburger
      if (spans) {
        spans[0].style.transform = 'none';
        spans[1].style.opacity = '1';
        spans[2].style.transform = 'none';
      }

      // 4. Reset items instantly so they are ready for the next open animation
      items.forEach((item) => {
        item.classList.remove('opacity-100', 'translate-y-0');
        item.classList.add('opacity-0', 'translate-y-8');
        (item as HTMLElement).style.transitionDuration = '200ms'; 
      });
    }
  });
</script>